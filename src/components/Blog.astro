---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
---

<section id="blog" class="py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 fade-in">
      <p class="text-copper-600 dark:text-copper-400 font-mono text-sm font-medium mb-3 tracking-widest uppercase">Blog</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white">Latest Thoughts</h2>
      <div class="w-16 h-1 bg-copper-600 rounded-full mx-auto mt-4"></div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6 fade-in">
      {sorted.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="group p-6 rounded-2xl bg-white dark:bg-sand-800 border border-sand-300 dark:border-sand-700 card-glow"
        >
          <span class="text-xs font-mono text-sand-500 dark:text-sand-600">
            {new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
          <h3 class="mt-3 font-semibold text-slate-900 dark:text-white group-hover:text-copper-600 dark:group-hover:text-copper-400 transition-colors">
            {post.data.title}
          </h3>
          <p class="mt-2 text-sm text-sand-600 dark:text-sand-400 leading-relaxed line-clamp-2 sm:line-clamp-3">
            {post.data.description}
          </p>
          <div class="flex flex-wrap gap-2 mt-4">
            {post.data.tags.map((tag) => (
              <span class="px-2 py-0.5 text-xs font-medium bg-sand-200 dark:bg-sand-700 text-sand-600 dark:text-sand-400 rounded">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-10">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 py-2 text-sm font-medium text-copper-600 dark:text-copper-400 hover:text-copper-700 dark:hover:text-copper-300 transition-colors"
      >
        Read All Posts
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
