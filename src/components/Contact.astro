<section id="contact" class="py-24 bg-sand-100 dark:bg-sand-900/50 relative overflow-hidden">
  <div class="absolute bottom-0 right-0 w-72 h-72 pointer-events-none opacity-5 dark:opacity-[0.03] hidden md:block">
    <svg viewBox="0 0 200 200" fill="none" class="w-full h-full">
      <path d="M0 40 L 200 40" stroke="currentColor" stroke-width="1" class="text-copper-600"/>
      <path d="M0 65 L 200 65" stroke="currentColor" stroke-width="0.8" class="text-copper-600" stroke-dasharray="4 4"/>
      <path d="M0 90 L 200 90" stroke="currentColor" stroke-width="0.6" class="text-copper-600"/>
      <path d="M0 115 L 200 115" stroke="currentColor" stroke-width="0.5" class="text-copper-600" stroke-dasharray="2 6"/>
      <path d="M0 140 L 200 140" stroke="currentColor" stroke-width="0.4" class="text-copper-600"/>
      <path d="M0 165 L 200 165" stroke="currentColor" stroke-width="0.3" class="text-copper-600" stroke-dasharray="1 8"/>
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 fade-in">
      <p class="text-copper-600 dark:text-copper-400 font-mono text-sm font-medium mb-3 tracking-widest uppercase">Contact</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white">Get In Touch</h2>
      <div class="w-16 h-1 bg-copper-600 rounded-full mx-auto mt-4"></div>
      <p class="mt-4 text-sand-600 dark:text-sand-400 max-w-xl mx-auto">
        Working on a mining project? Have a question about the field? 
        Lets talk -- I'm always open to new conversations.
      </p>
    </div>

    <div class="grid md:grid-cols-5 gap-12 max-w-4xl mx-auto fade-in">
      <div class="md:col-span-3">
        <form action="https://api.web3forms.com/submit" method="POST" class="space-y-5">
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
          <input type="hidden" name="subject" value="New Portfolio Contact" />
          
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm font-medium text-sand-700 dark:text-sand-300 mb-1.5">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-lg border border-sand-300 dark:border-sand-600 bg-white dark:bg-sand-800 text-slate-900 dark:text-white placeholder-sand-400 focus:ring-2 focus:ring-copper-500 focus:border-transparent outline-none transition-all text-sm"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-sand-700 dark:text-sand-300 mb-1.5">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-lg border border-sand-300 dark:border-sand-600 bg-white dark:bg-sand-800 text-slate-900 dark:text-white placeholder-sand-400 focus:ring-2 focus:ring-copper-500 focus:border-transparent outline-none transition-all text-sm"
                placeholder="you@example.com"
              />
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-sand-700 dark:text-sand-300 mb-1.5">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full px-4 py-3 rounded-lg border border-sand-300 dark:border-sand-600 bg-white dark:bg-sand-800 text-slate-900 dark:text-white placeholder-sand-400 focus:ring-2 focus:ring-copper-500 focus:border-transparent outline-none transition-all text-sm resize-none"
              placeholder="Tell me about your project or question..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="btn-scale w-full sm:w-auto px-6 py-3 bg-copper-600 hover:bg-copper-700 text-white font-medium rounded-lg transition-all shadow-lg shadow-copper-600/20 text-sm"
          >
            Send Message
          </button>
        </form>
      </div>

      <div class="md:col-span-2 space-y-6">
        <div class="p-5 rounded-xl bg-white dark:bg-sand-800 border border-sand-300 dark:border-sand-700">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-3 text-sm uppercase tracking-wider">Connect</h3>
          <div class="space-y-3">
            <a href="mailto:hello@ntang.my.id" class="flex items-center gap-3 text-sm text-sand-700 dark:text-sand-400 hover:text-copper-600 dark:hover:text-copper-400 transition-colors">
              <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              hello@ntang.my.id
            </a>
            <a href="https://linkedin.com/in/ntang" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-sm text-sand-700 dark:text-sand-400 hover:text-copper-600 dark:hover:text-copper-400 transition-colors">
              <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
            <a href="https://github.com/ntang" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-sm text-sand-700 dark:text-sand-400 hover:text-copper-600 dark:hover:text-copper-400 transition-colors">
              <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
              GitHub
            </a>
          </div>
        </div>

        <div class="p-5 rounded-xl bg-white dark:bg-sand-800 border border-sand-300 dark:border-sand-700">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 text-sm uppercase tracking-wider">Location</h3>
          <p class="text-sm text-sand-600 dark:text-sand-400">
            Yogyakarta, DIY<br />
            Indonesia
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
