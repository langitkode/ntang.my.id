---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} - Ntang`} description={post.data.description}>
  <Nav />
  <main class="pt-24 pb-16">
    <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="pt-8 pb-12">
        <a
          href="/blog"
          class="inline-flex items-center gap-1.5 text-sm text-sand-600 dark:text-sand-400 hover:text-copper-600 dark:hover:text-copper-400 transition-colors mb-8"
        >
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Back to Blog
        </a>

        <span class="inline-block text-sm font-mono text-sand-500 dark:text-sand-600 mb-4">
          {new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </span>
        <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white leading-tight">
          {post.data.title}
        </h1>
        <p class="mt-3 text-lg text-sand-600 dark:text-sand-400">
          {post.data.description}
        </p>
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag) => (
            <span class="px-3 py-1 text-xs font-medium bg-sand-200 dark:bg-sand-700 text-sand-700 dark:text-sand-400 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      </div>

      <div class="blog-content max-w-none pb-16">
        <Content />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
